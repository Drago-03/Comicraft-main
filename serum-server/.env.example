# Serum REST Server — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to version control.

# Port for the Serum REST server (default: 3001)
PORT=3001

# Solana RPC endpoint
# Mainnet: https://api.mainnet-beta.solana.com
# Devnet:  https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Base58-encoded keypair for signing orders
# Generate with: solana-keygen new --outfile payer.json && cat payer.json
# ⚠️  NEVER commit this value to version control
PAYER_KEYPAIR=YOUR_BASE58_ENCODED_PRIVATE_KEY

# Serum market addresses — obtain from https://github.com/project-serum/serum-ts/blob/master/packages/serum/src/markets.json
CRAFTS_SOL_MARKET=YOUR_CRAFTS_SOL_MARKET_ADDRESS
CRAFTS_USDC_MARKET=YOUR_CRAFTS_USDC_MARKET_ADDRESS

# Comicraft frontend origin for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://comicraft.xyz
